{
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(python -m pytest *)",
      "Bash(gh pr *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(mypy givenergy_modbus *)",
      "Bash(git ls-remote *)",
      "Bash(gh run *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(prek run *)",
      "Skill(commit-commands:commit)",
      "Skill(commit-commands:commit:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {"tool_name": "Edit", "file_pattern": "**/*.py"},
        "hooks": [
          {
            "type": "command",
            "command": "uv run --group test ruff check --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" && uv run --group test ruff format \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": {"tool_name": "Edit", "file_pattern": "{uv.lock,.env*}"},
        "hooks": [
          {
            "type": "block",
            "reason": "Do not edit uv.lock or .env files directly"
          }
        ]
      }
    ]
  }
}
